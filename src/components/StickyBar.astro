---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const prefix = locale === "en" ? "/en" : "";
---

<div class="fixed bottom-0 left-0 right-0 z-50 border-t border-stone-200 bg-white/95 px-4 py-3 backdrop-blur md:hidden">
  <div class="mx-auto flex max-w-lg items-center justify-between gap-3">
    <span class="text-sm font-medium text-ink">{dict.sticky.text}</span>
    <a
      href={`${prefix}/#waitlist`}
      class="shrink-0 rounded-full bg-terracotta px-5 py-2 text-sm font-semibold text-white"
    >
      {dict.sticky.cta}
    </a>
  </div>
</div>
