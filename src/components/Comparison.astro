---
import type { Locale } from "../lib/i18n";
import { t, localePath } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const c = t(locale).comparison;
const prefix = locale === "en" ? "/en" : "";
---

<section id="compare" class="bg-ink px-4 py-16 text-cream sm:px-6 sm:py-20">
  <div class="mx-auto max-w-4xl">
    <h2 class="font-display text-3xl font-semibold sm:text-4xl">{c.title}</h2>
    <p class="mt-4 text-cream/75">{c.subtitle}</p>
    <div class="mt-10 overflow-x-auto rounded-2xl border border-white/10">
      <table class="w-full min-w-[540px] text-left text-sm">
        <thead>
          <tr class="border-b border-white/10 bg-white/5">
            {
              c.headers.map((h, i) => (
                <th class={`px-4 py-3 font-semibold ${i === 1 ? "text-terracotta" : ""}`}>{h}</th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            c.rows.map((row) => (
              <tr class="border-b border-white/5">
                {row.map((cell, i) => (
                  <td class={`px-4 py-3 ${i === 0 ? "font-medium text-cream/90" : "text-cream/70"}`}>
                    {cell}
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href={`${prefix}/#precos`}
        class="inline-flex rounded-full bg-terracotta px-6 py-3 text-sm font-semibold text-white hover:bg-terracotta-dark"
      >
        {c.ctaPricing}
      </a>
      <a
        href={`${localePath(locale)}#waitlist`}
        class="inline-flex rounded-full border border-cream/30 px-6 py-3 text-sm font-semibold text-cream hover:border-cream"
      >
        {c.ctaRequest}
      </a>
    </div>
  </div>
</section>
