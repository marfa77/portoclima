---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section id="niche" class="border-t border-stone-200/80 bg-white px-4 py-16 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-3xl font-semibold text-ink sm:text-4xl">{dict.manifest.title}</h2>
    <div class="mt-8 space-y-5 text-lg leading-relaxed text-ink-muted">
      <p>{dict.manifest.p1}</p>
      <p>{dict.manifest.p2}</p>
      <p>{dict.manifest.p3}</p>
    </div>
    <blockquote class="mt-10 border-l-4 border-terracotta pl-5 text-ink italic">
      {dict.manifest.disclaimer}
    </blockquote>
  </div>
</section>

<section class="bg-cream px-4 py-14 sm:px-6" id="distritos">
  <div class="mx-auto max-w-5xl">
    <h3 class="font-display mb-2 text-2xl font-semibold text-ink">{dict.districts.title}</h3>
    <p class="mb-8 max-w-3xl text-sm leading-relaxed text-ink-muted sm:text-base">{dict.districts.subtitle}</p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        dict.districts.items.map((item) => (
          <article class="card-shadow rounded-2xl border border-stone-200/60 bg-white p-5">
            <h4 class="font-display font-semibold text-azulejo">{item.name}</h4>
            <p class="mt-2 text-sm leading-relaxed text-ink-muted">{item.text}</p>
          </article>
        ))
      }
    </div>
    <div class="card-shadow mt-6 rounded-2xl border border-azulejo/20 bg-azulejo/5 p-6">
      <h4 class="font-display font-semibold text-ink">{dict.districts.landlord.title}</h4>
      <p class="mt-2 text-sm leading-relaxed text-ink-muted">{dict.districts.landlord.text}</p>
    </div>
  </div>
</section>
