---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const p = t(locale).privacy;
---

<article class="mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-20">
  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta">{p.eyebrow}</p>
  <h1 class="font-display mt-3 text-3xl font-semibold text-ink sm:text-4xl">{p.title}</h1>
  <p class="mt-3 text-sm text-ink-muted">{p.updated}</p>
  <p class="legal-prose mt-6 text-base leading-relaxed text-ink-muted">{p.intro}</p>

  <div class="legal-prose mt-10 space-y-10">
    {
      p.sections.map((section) => (
        <section id={section.id}>
          <h2 class="font-display text-xl font-semibold text-ink sm:text-2xl">{section.title}</h2>
          {section.paragraphs?.map((para) => (
            <p class="mt-4 leading-relaxed text-ink-muted">{para}</p>
          ))}
          {section.list && (
            <ul class="mt-4 list-disc space-y-2 pl-5 text-ink-muted">
              {section.list.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
          {section.links && (
            <ul class="mt-4 space-y-2">
              {section.links.map((link) => (
                <li>
                  <a href={link.url} class="text-azulejo underline hover:no-underline" target="_blank" rel="noopener noreferrer">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </section>
      ))
    }
  </div>
</article>
