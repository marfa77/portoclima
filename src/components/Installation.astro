---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";
import modelsData from "../data/models.json";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const install = dict.installation;
const videoId = modelsData.manufacturer.promoVideoYoutubeId;
const videoUrl = modelsData.manufacturer.promoVideoUrl;
---

<section id="install" class="border-t border-stone-200/80 px-4 py-16 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-5xl">
    <h2 class="font-display text-3xl font-semibold text-ink sm:text-4xl">{install.title}</h2>
    <p class="mt-4 max-w-2xl text-lg text-ink-muted">{install.subtitle}</p>
    <ol class="mt-10 grid gap-4 sm:grid-cols-2">
      {
        install.steps.map((step, i) => (
          <li class="card-shadow relative rounded-2xl border border-stone-200/60 bg-white p-6">
            <span class="font-display text-4xl font-bold text-terracotta/30">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="font-display mt-2 text-xl font-semibold text-ink">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-muted">{step.text}</p>
          </li>
        ))
      }
    </ol>

    {
      videoId && (
        <figure class="card-shadow mt-8 overflow-hidden rounded-2xl border border-stone-200/80 bg-white">
          <div class="aspect-video bg-stone-900">
            <iframe
              src={`https://www.youtube-nocookie.com/embed/${videoId}`}
              title={install.videoTitle}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
              class="h-full w-full border-0"
            />
          </div>
          <figcaption class="border-t border-stone-100 px-4 py-3 text-xs leading-relaxed text-ink-muted sm:px-5">
            {install.videoCaption}{" "}
            <a
              href={videoUrl}
              class="text-azulejo underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              YouTube · {modelsData.manufacturer.name}
            </a>
          </figcaption>
        </figure>
      )
    }
  </div>
</section>
