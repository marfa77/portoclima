---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";
import { siteConfig } from "../data/site";
import { serviceArea } from "../data/service-area";
import modelsData from "../data/models.json";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const siteUrl = `https://${siteConfig.domain}`;
const businessId = `${siteUrl}/#business`;
const dualPackageEur = dict.pricing.dualPackageEur;

const modelOffers = modelsData.models.map((model) => ({
  "@type": "Offer",
  "@id": `${siteUrl}/#offer-${model.id}`,
  url: `${siteUrl}/#precos`,
  priceCurrency: "EUR",
  price: model.packageTurnkeyEur,
  availability: "https://schema.org/PreOrder",
  itemOffered: {
    "@type": "Service",
    name: locale === "pt" ? `Instalação chave-na-mão — ${model.name}` : `Turnkey install — ${model.name}`,
    description: locale === "pt" ? model.segmentLabelPt : model.segmentLabelEn,
    provider: { "@id": businessId },
    areaServed: serviceArea.labelEn,
  },
  seller: { "@id": businessId },
}));

const dualOffer = {
  "@type": "Offer",
  "@id": `${siteUrl}/#offer-dual-12800`,
  url: `${siteUrl}/#precos`,
  priceCurrency: "EUR",
  price: dualPackageEur,
  availability: "https://schema.org/PreOrder",
  itemOffered: {
    "@type": "Service",
    name: locale === "pt" ? dict.pricing.table.dualRow : dict.pricing.table.dualRow,
    description:
      locale === "pt"
        ? "Dois ForceClima 12800 na mesma morada — open-space"
        : "Two ForceClima 12800 at the same address — open space",
    provider: { "@id": businessId },
    areaServed: serviceArea.labelEn,
  },
  seller: { "@id": businessId },
};

const howToSteps = dict.installation.steps.map((step, i) => ({
  "@type": "HowToStep",
  position: i + 1,
  name: step.title,
  text: step.text,
}));
---

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": businessId,
      name: siteConfig.brand,
      description: dict.meta.description,
      url: `${siteUrl}/`,
      email: siteConfig.contactEmail,
      areaServed: [
        { "@type": "City", name: "Porto", containedInPlace: { "@type": "Country", name: "Portugal" } },
        {
          "@type": "GeoCircle",
          geoMidpoint: {
            "@type": "GeoCoordinates",
            latitude: serviceArea.center.lat,
            longitude: serviceArea.center.lng,
          },
          geoRadius: String(serviceArea.radiusMeters),
          description:
            locale === "pt"
              ? `Raio de ${serviceArea.radiusKm} km a partir do Porto`
              : `${serviceArea.radiusKm} km radius from Porto`,
        },
      ],
      priceRange: "€€",
      openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        description: locale === "pt"
          ? `Mediante marcação — ${serviceArea.shortPt}`
          : `By appointment — ${serviceArea.shortEn}`,
      },
      makesOffer: modelOffers.concat(dualOffer).map((o) => ({ "@id": o["@id"] })),
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#org`,
      name: siteConfig.brand,
      url: `${siteUrl}/`,
      email: siteConfig.contactEmail,
    },
    ...modelOffers,
    dualOffer,
    {
      "@type": "FAQPage",
      mainEntity: dict.faq.items.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    },
    {
      "@type": "HowTo",
      name: dict.installation.title,
      description: dict.installation.subtitle,
      step: howToSteps,
    },
  ],
})} />
