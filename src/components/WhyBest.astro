---
import type { Locale } from "../lib/i18n";
import { t, localePath } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const w = t(locale).whyBest;
const prefix = locale === "en" ? "/en" : "";
---

<section id="porque" class="border-t border-stone-200/80 bg-white px-4 py-16 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-5xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta">{w.eyebrow}</p>
    <h2 class="font-display mt-3 max-w-3xl text-3xl font-semibold leading-tight text-ink sm:text-4xl">
      {w.title}
    </h2>
    <p class="mt-5 max-w-3xl text-lg leading-relaxed text-ink-muted">{w.subtitle}</p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {w.seasons.map((season) => (
        <article class="card-shadow rounded-2xl border border-stone-200/80 bg-cream/30 p-5">
          <p class="text-2xl" aria-hidden="true">{season.icon}</p>
          <h3 class="font-display mt-2 text-lg font-semibold text-ink">{season.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-muted">{season.text}</p>
        </article>
      ))}
    </div>

    <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {w.pillars.map((item) => (
        <li class="flex gap-4 rounded-2xl border border-azulejo/15 bg-azulejo/5 p-5">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-terracotta text-lg text-white" aria-hidden="true">
            {item.icon}
          </span>
          <div>
            <h3 class="font-semibold text-ink">{item.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-ink-muted">{item.text}</p>
          </div>
        </li>
      ))}
    </ul>

    <div class="mt-12 overflow-x-auto rounded-2xl border border-stone-200/80">
      <table class="w-full min-w-[640px] text-left text-sm">
        <thead>
          <tr class="border-b border-stone-200 bg-cream/60 text-xs uppercase tracking-wide text-ink-muted">
            <th class="px-4 py-3 font-semibold">{w.compare.headers.criteria}</th>
            <th class="px-4 py-3 font-semibold text-terracotta">{w.compare.headers.us}</th>
            <th class="px-4 py-3 font-semibold">{w.compare.headers.split}</th>
            <th class="px-4 py-3 font-semibold">{w.compare.headers.store}</th>
          </tr>
        </thead>
        <tbody>
          {w.compare.rows.map((row) => (
            <tr class="border-b border-stone-100 last:border-0">
              <td class="px-4 py-3 font-medium text-ink">{row.criteria}</td>
              <td class="px-4 py-3 font-medium text-terracotta">{row.us}</td>
              <td class="px-4 py-3 text-ink-muted">{row.split}</td>
              <td class="px-4 py-3 text-ink-muted">{row.store}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <blockquote class="mt-10 border-l-4 border-terracotta bg-cream/50 py-4 pl-5 pr-4">
      <p class="font-display text-lg font-semibold text-ink">{w.quote}</p>
      <p class="mt-2 text-sm text-ink-muted">{w.quoteSub}</p>
    </blockquote>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={`${prefix}/#precos`}
        class="inline-flex rounded-full bg-terracotta px-6 py-3 text-sm font-semibold text-white hover:bg-terracotta-dark"
      >
        {w.ctaPricing}
      </a>
      <a
        href={`${localePath(locale)}#waitlist`}
        class="inline-flex rounded-full border border-ink/15 px-6 py-3 text-sm font-semibold text-ink hover:border-azulejo hover:text-azulejo"
      >
        {w.ctaRequest}
      </a>
    </div>
  </div>
</section>
