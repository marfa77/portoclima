---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";
import modelsData from "../data/models.json";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const p = t(locale).pricing;
const prefix = locale === "en" ? "/en" : "";
const fmt = (n: number) =>
  n.toLocaleString(locale === "pt" ? "pt-PT" : "en-GB", { maximumFractionDigits: 0 }) + "€";
---

<section id="precos" class="border-t border-stone-200/80 bg-cream-dark px-4 py-16 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-5xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta">{p.eyebrow}</p>
    <h2 class="font-display mt-3 text-3xl font-semibold text-ink sm:text-4xl">{p.title}</h2>
    <p class="mt-4 max-w-3xl text-lg leading-relaxed text-ink-muted">{p.intro}</p>
    <p class="mt-2 text-sm font-medium text-azulejo">{p.vatNote}</p>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {modelsData.models.map((model) => (
        <article class="card-shadow flex flex-col rounded-2xl border border-stone-200/80 bg-white p-6">
          <p class="text-xs font-semibold uppercase tracking-wide text-terracotta">
            {locale === "pt" ? model.segmentLabelPt : model.segmentLabelEn}
          </p>
          <p class="font-display mt-4 text-4xl font-semibold text-ink">
            {fmt(model.packageTurnkeyEur)}
          </p>
          <p class="mt-1 text-sm font-medium text-ink">{p.turnkeyLabel}</p>
          <p class="mt-3 text-xs text-ink-muted">
            {p.machineRef}: {fmt(model.priceRetailEur)} ({p.machineRefNote})
          </p>
          <ul class="mt-5 flex-1 space-y-2 border-t border-stone-100 pt-5 text-sm text-ink-muted">
            {p.includes.map((item) => (
              <li class="flex gap-2">
                <span class="text-terracotta" aria-hidden="true">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a
            href={`${prefix}/#waitlist`}
            class="mt-6 inline-flex justify-center rounded-full bg-terracotta px-5 py-2.5 text-sm font-semibold text-white hover:bg-terracotta-dark"
          >
            {p.cta}
          </a>
        </article>
      ))}
    </div>

    <div class="mt-10 overflow-x-auto rounded-2xl border border-stone-200/80 bg-white">
      <table class="w-full min-w-[720px] text-left text-sm">
        <thead>
          <tr class="border-b border-stone-200 bg-cream/60 text-xs uppercase tracking-wide text-ink-muted">
            <th class="px-4 py-3 font-semibold">{p.table.package}</th>
            <th class="px-4 py-3 font-semibold">{p.table.machine}</th>
            <th class="px-4 py-3 font-semibold">{p.table.service}</th>
            <th class="px-4 py-3 font-semibold">{p.table.turnkey}</th>
          </tr>
        </thead>
        <tbody>
          {modelsData.models.map((model) => {
            const service = model.packageTurnkeyEur - model.priceRetailEur;
            return (
              <tr class="border-b border-stone-100 last:border-0">
                <td class="px-4 py-4 font-medium text-ink">
                  {locale === "pt" ? model.segmentLabelPt : model.segmentLabelEn}
                </td>
                <td class="px-4 py-4 text-ink-muted">{fmt(model.priceRetailEur)}</td>
                <td class="px-4 py-4 text-ink-muted">+ {fmt(service)}</td>
                <td class="px-4 py-4 font-semibold text-terracotta">{fmt(model.packageTurnkeyEur)}</td>
              </tr>
            );
          })}
          <tr class="bg-cream/40">
            <td class="px-4 py-4 font-medium text-ink" colspan="3">
              {p.table.dualRow}
            </td>
            <td class="px-4 py-4 font-semibold text-terracotta">{fmt(p.dualPackageEur)}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <ul class="mt-8 grid gap-2 sm:grid-cols-2">
      {p.footnotes.map((note) => (
        <li class="text-xs leading-relaxed text-ink-muted">· {note}</li>
      ))}
    </ul>

    <p class="mt-8">
      <a href={`${prefix}/#modelos`} class="text-sm font-semibold text-azulejo hover:underline">
        {p.modelsLink}
      </a>
    </p>
  </div>
</section>
