---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section id="faq" class="px-4 py-14 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-2xl font-semibold text-ink sm:text-4xl">{dict.faq.title}</h2>
    <div class="mt-6 divide-y divide-stone-200 border-y border-stone-200">
      {
        dict.faq.items.map((item) => (
          <details class="group py-4">
            <summary class="tap-target cursor-pointer list-none py-1 font-medium text-ink marker:content-none group-open:text-azulejo">
              <span class="flex items-start justify-between gap-4">
                {item.q}
                <span class="text-terracotta transition group-open:rotate-45">+</span>
              </span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-ink-muted">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
