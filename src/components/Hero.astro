---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";
import { siteConfig } from "../data/site";
import attribution from "../../public/images/attribution.json";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const prefix = locale === "en" ? "/en" : "";
const photoCredit = attribution.photographer;
const photoUrl = attribution.pexelsUrl;
const showWhatsApp = siteConfig.whatsappEnabled;
const mailto = `mailto:${siteConfig.contactEmail}`;
---

<section class="hero-grain relative overflow-hidden px-4 pb-12 pt-6 sm:px-6 sm:pb-24 sm:pt-12">
  <div class="mx-auto grid max-w-5xl items-center gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12">
    <div class="relative z-10 order-2 lg:order-none">
      <p class="font-display text-2xl font-semibold tracking-tight text-azulejo sm:text-3xl">{dict.hero.brand}</p>
      <p class="mt-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-ink-muted sm:text-sm">
        {dict.hero.eyebrow}
      </p>
      <h1 class="font-display mt-3 max-w-3xl text-[1.7rem] font-semibold leading-[1.15] text-ink sm:text-5xl lg:text-[3.1rem] lg:leading-tight">
        {dict.hero.title}
      </h1>
      <p class="mt-4 text-sm font-medium text-ink sm:text-base">{dict.hero.highlights}</p>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-ink-muted sm:text-xl">
        {dict.hero.subtitle}
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a
          href={`${prefix}/#precos`}
          class="tap-target inline-flex min-h-12 items-center justify-center rounded-full bg-terracotta px-8 py-3.5 text-center text-base font-semibold text-white shadow-lg shadow-terracotta/20 transition active:bg-terracotta-dark"
        >
          {dict.hero.ctaModels}
        </a>
        {
          showWhatsApp ? (
            <a
              href={`${prefix}/#waitlist`}
              class="tap-target inline-flex min-h-12 items-center justify-center rounded-full border border-ink/15 bg-white/60 px-8 py-3.5 text-base font-semibold text-ink backdrop-blur transition active:border-azulejo active:text-azulejo"
            >
              {dict.hero.ctaWaitlist}
            </a>
          ) : (
            <a
              href={mailto}
              class="tap-target inline-flex min-h-12 items-center justify-center rounded-full border border-ink/15 bg-white/60 px-8 py-3.5 text-base font-semibold text-ink backdrop-blur transition active:border-azulejo active:text-azulejo"
            >
              {dict.hero.ctaEmail}
            </a>
          )
        }
        {
          !showWhatsApp && (
            <a
              href={`${prefix}/#waitlist`}
              class="tap-target inline-flex min-h-12 items-center justify-center rounded-full border border-azulejo/25 px-8 py-3.5 text-base font-semibold text-azulejo transition active:bg-azulejo/5"
            >
              {dict.hero.ctaWaitlist}
            </a>
          )
        }
      </div>
      <p class="mt-4 text-sm font-medium text-ink">{dict.hero.note}</p>
      <details class="mt-3 lg:hidden">
        <summary class="cursor-pointer text-xs font-semibold text-ink-muted">{dict.hero.serviceArea}</summary>
        <p class="mt-2 text-xs leading-relaxed text-ink-muted">{dict.hero.serviceAreaDetail}</p>
      </details>
      <p class="mt-3 hidden text-xs leading-relaxed text-ink-muted lg:block">
        <span class="font-semibold text-ink-muted">{dict.hero.serviceArea}</span>
        {" — "}
        {dict.hero.serviceAreaDetail}
      </p>
    </div>

    <div class="relative z-10 order-1 lg:order-none">
      <div class="card-shadow relative overflow-hidden rounded-3xl border border-stone-200/80 bg-white/40 p-2 backdrop-blur-sm">
        <img
          src="/images/hero.webp"
          alt={
            locale === "pt"
              ? "Ar condicionado móvel instalado num apartamento no Porto"
              : "Portable air conditioner installed in a Porto apartment"
          }
          width="1600"
          height="1000"
          class="aspect-[16/10] w-full rounded-2xl object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <p class="mt-2 px-1 text-[10px] leading-relaxed text-ink-muted/80 sm:text-xs">
        {locale === "pt" ? "Foto" : "Photo"}:{" "}
        <a href={photoUrl} class="underline hover:text-azulejo" target="_blank" rel="noopener noreferrer">
          {photoCredit}
        </a>
        {" · "}
        <a href="https://www.pexels.com" class="underline hover:text-azulejo" target="_blank" rel="noopener noreferrer">
          Pexels
        </a>
      </p>
    </div>
  </div>

  <div
    class="pointer-events-none absolute -right-20 top-10 h-72 w-72 rounded-full bg-azulejo/10 blur-3xl"
    aria-hidden="true"
  ></div>
</section>
