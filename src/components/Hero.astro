---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";
import attribution from "../../public/images/attribution.json";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const prefix = locale === "en" ? "/en" : "";
const photoCredit = attribution.photographer;
const photoUrl = attribution.pexelsUrl;
---

<section class="hero-grain relative overflow-hidden px-4 pb-16 pt-8 sm:px-6 sm:pb-24 sm:pt-12">
  <div class="mx-auto grid max-w-5xl items-center gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12">
    <div class="relative z-10">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-azulejo sm:text-sm">
        {dict.hero.eyebrow}
      </p>
      <h1 class="font-display max-w-3xl text-4xl font-semibold leading-tight text-ink sm:text-5xl lg:text-[3.1rem]">
        {dict.hero.title}
      </h1>
      <ul class="mt-5 flex flex-wrap gap-2" aria-label={locale === "pt" ? "O que vendemos" : "What we sell"}>
        {
          dict.hero.pills.map((pill) => (
            <li class="inline-flex items-center gap-1.5 rounded-full border border-azulejo/20 bg-white/80 px-3 py-1.5 text-xs font-semibold text-ink backdrop-blur sm:text-sm">
              <span class="text-azulejo" aria-hidden="true">✓</span>
              {pill}
            </li>
          ))
        }
      </ul>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-muted sm:text-xl">
        {dict.hero.subtitle}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={`${prefix}/#precos`}
          class="inline-flex items-center justify-center rounded-full bg-terracotta px-8 py-3.5 text-center text-sm font-semibold text-white shadow-lg shadow-terracotta/20 transition hover:bg-terracotta-dark"
        >
          {dict.hero.ctaModels}
        </a>
        <a
          href={`${prefix}/#waitlist`}
          class="inline-flex items-center justify-center rounded-full border border-ink/15 bg-white/60 px-8 py-3.5 text-sm font-semibold text-ink backdrop-blur transition hover:border-azulejo hover:text-azulejo"
        >
          {dict.hero.ctaWaitlist}
        </a>
      </div>
      <p class="mt-5 text-sm font-medium text-ink">{dict.hero.note}</p>
      <p class="mt-3 text-xs leading-relaxed text-ink-muted">
        <span class="font-semibold text-ink-muted">{dict.hero.serviceArea}</span>
        {" — "}
        {dict.hero.serviceAreaDetail}
      </p>
    </div>

    <div class="relative z-10">
      <div class="card-shadow relative overflow-hidden rounded-3xl border border-stone-200/80 bg-white/40 p-2 backdrop-blur-sm">
        <img
          src="/images/hero.webp"
          alt={
            locale === "pt"
              ? "Ar condicionado móvel instalado num apartamento no Porto"
              : "Portable air conditioner installed in a Porto apartment"
          }
          width="1600"
          height="1000"
          class="aspect-[16/10] w-full rounded-2xl object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <div
          class="absolute bottom-4 left-4 right-4 flex items-center gap-3 rounded-2xl border border-white/60 bg-white/95 px-4 py-3 shadow-lg backdrop-blur sm:bottom-5 sm:left-5 sm:right-auto sm:max-w-xs"
          aria-hidden="true"
        >
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-azulejo text-white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
              <rect x="5" y="3" width="14" height="18" rx="2" stroke="currentColor" stroke-width="1.5"></rect>
              <path d="M8 8h8M8 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
              <path
                d="M9 18c.8 1.2 2 2 3.5 2s2.7-.8 3.5-2"
                stroke="#c45c3e"
                stroke-width="1.5"
                stroke-linecap="round"
              ></path>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-ink">{dict.hero.imageBadge}</p>
            <p class="text-xs text-ink-muted">{dict.hero.imageBadgeSub}</p>
          </div>
        </div>
      </div>
      <p class="mt-2 px-1 text-[10px] leading-relaxed text-ink-muted/80 sm:text-xs">
        {locale === "pt" ? "Foto" : "Photo"}:{" "}
        <a href={photoUrl} class="underline hover:text-azulejo" target="_blank" rel="noopener noreferrer">
          {photoCredit}
        </a>
        {" · "}
        <a href="https://www.pexels.com" class="underline hover:text-azulejo" target="_blank" rel="noopener noreferrer">
          Pexels
        </a>
      </p>
    </div>
  </div>

  <div
    class="pointer-events-none absolute -right-20 top-10 h-72 w-72 rounded-full bg-azulejo/10 blur-3xl"
    aria-hidden="true"
  ></div>
</section>
