---
import type { Locale } from "../lib/i18n";
import { t, localePath } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const prefix = locale === "en" ? "/en" : "";
---

<header class="sticky top-0 z-40 border-b border-stone-200/80 bg-cream/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href={localePath(locale)} class="flex shrink-0 items-center gap-2.5">
      <img src="/logo.svg" alt="Porto Clima" width="168" height="32" class="h-8 w-auto sm:h-9" />
    </a>
    <nav class="hidden items-center gap-5 text-sm text-ink-muted md:flex">
      <a href={`${prefix}/#modelos`} class="hover:text-azulejo">{dict.nav.niche}</a>
      <a href={`${prefix}/#precos`} class="hover:text-azulejo">{dict.nav.pricing}</a>
      <a href={`${prefix}/#install`} class="hover:text-azulejo">{dict.nav.install}</a>
      <a href={`${prefix}/#compare`} class="hover:text-azulejo">{dict.nav.compare}</a>
      <a href={`${prefix}/#faq`} class="hover:text-azulejo">{dict.nav.faq}</a>
      <a href={`${prefix}/#waitlist`} class="font-medium text-terracotta hover:text-terracotta-dark">{dict.nav.waitlist}</a>
    </nav>
    <a
      href={locale === "pt" ? "/en/" : "/"}
      class="text-sm font-medium text-azulejo hover:underline"
    >
      {dict.nav.langSwitch}
    </a>
  </div>
</header>
