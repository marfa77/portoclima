---
import type { Locale } from "../lib/i18n";
import { t } from "../lib/i18n";
import type { GuideEntry } from "../lib/guides";
import { guidePath } from "../lib/guides";

interface Props {
  locale: Locale;
  guides: GuideEntry[];
}

const { locale, guides } = Astro.props;
const dict = t(locale);
---

{guides.length > 0 && (
  <section class="mt-14 rounded-2xl border border-stone-200/80 bg-white p-6 card-shadow">
    <h2 class="font-display text-xl font-semibold text-ink">{dict.guides.relatedTitle}</h2>
    <p class="mt-2 text-sm text-ink-muted">{dict.guides.relatedIntro}</p>
    <ul class="mt-6 space-y-4">
      {guides.map((guide) => (
        <li>
          <a
            href={guidePath(locale, guide.id)}
            class="group block rounded-xl border border-stone-100 p-4 transition hover:border-terracotta/30 hover:bg-cream/40"
          >
            <p class="text-xs font-semibold uppercase tracking-wide text-terracotta">
              {guide.data.estimated_minutes} min · {guide.data.primary_intent}
            </p>
            <p class="font-display mt-1 text-lg font-semibold text-ink group-hover:text-terracotta">
              {guide.data.title}
            </p>
            <p class="mt-1 text-sm text-ink-muted">{guide.data.excerpt}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
