---
import "../styles/global.css";
import type { Locale } from "../lib/i18n";
import { localePath, t } from "../lib/i18n";
import { siteConfig } from "../data/site";
import { serviceArea } from "../data/service-area";
import GuideJsonLd from "../components/GuideJsonLd.astro";
import RelatedGuides from "../components/RelatedGuides.astro";
import GuideFunnel from "../components/GuideFunnel.astro";
import CookieNotice from "../components/CookieNotice.astro";
import type { GuideEntry } from "../lib/guides";
import { guideOgImage, guidesIndexPath } from "../lib/guides";

interface Props {
  locale: Locale;
  entry: GuideEntry;
  slug: string;
  alternatePath?: string;
  relatedGuides: GuideEntry[];
}

const { locale, entry, slug, alternatePath, relatedGuides } = Astro.props;
const d = entry.data;
const dict = t(locale);
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(guideOgImage(d.hero_image), Astro.site);
const aiDescription = `${d.quick_answer} ${d.excerpt}`.slice(0, 500);
const ptHref = locale === "pt" ? canonical.href : alternatePath ? new URL(alternatePath, Astro.site).href : new URL("/", Astro.site).href;
const enHref = locale === "en" ? canonical.href : alternatePath ? new URL(alternatePath, Astro.site).href : new URL("/en/", Astro.site).href;
---

<!doctype html>
<html lang={locale === "pt" ? "pt-PT" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#f7f2ea" />
    <title>{d.seo_title}</title>
    <meta name="description" content={d.seo_description} />
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content={d.tags.join(", ")} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="pt-PT" href={ptHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={ptHref} />
    <link rel="alternate" type="text/plain" href={new URL("/llms.txt", Astro.site)} />

    <meta name="ai:description" content={aiDescription} />
    <meta name="ai:category" content="porto-climate-guide" />

    <meta property="og:type" content="article" />
    <meta property="og:title" content={d.seo_title} />
    <meta property="og:description" content={d.seo_description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="article:published_time" content={d.date_published.toISOString()} />
    <meta property="article:modified_time" content={d.date_modified.toISOString()} />
    <meta property="og:locale" content={locale === "pt" ? "pt_PT" : "en_GB"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {siteConfig.plausibleDomain && (
      <script defer data-domain={siteConfig.plausibleDomain} src="https://plausible.io/js/script.js" />
    )}

    <GuideJsonLd locale={locale} entry={entry} slug={slug} />
  </head>
  <body class="antialiased body-mobile-pad">
    <p class="sr-only" data-ai="description">{aiDescription}</p>
    <slot name="header" />
    <main>
      <article>
        <header class="relative overflow-hidden border-b border-stone-200/80 bg-cream-dark">
          <div class="mx-auto grid max-w-5xl lg:grid-cols-2 lg:gap-8">
            <div class="order-2 px-4 py-8 sm:px-6 sm:py-16 lg:order-none lg:py-20">
              <nav class="text-xs text-ink-muted" aria-label="Breadcrumb">
                <a href={localePath(locale)} class="hover:text-azulejo">Porto Clima</a>
                <span aria-hidden="true"> · </span>
                <a href={guidesIndexPath(locale)} class="hover:text-azulejo">{dict.guides.indexTitle}</a>
              </nav>
              <p class="mt-4 text-xs font-semibold uppercase tracking-[0.2em] text-terracotta">
                {locale === "pt" ? serviceArea.shortPt : serviceArea.shortEn}
              </p>
              <h1 class="font-display mt-3 text-2xl font-semibold leading-snug text-ink sm:text-4xl lg:text-[2.5rem] lg:leading-tight">
                {d.title}
              </h1>
              <p class="guide-quick-answer mt-4 text-base leading-relaxed text-ink-muted sm:text-lg">{d.quick_answer}</p>
              <p class="mt-4 text-sm text-ink-muted">
                {d.estimated_minutes} min · {d.date_modified.toLocaleDateString(locale === "pt" ? "pt-PT" : "en-GB")}
              </p>
            </div>
            <figure class="relative order-1 min-h-[200px] sm:min-h-[240px] lg:order-none lg:min-h-full">
              <img
                src={d.hero_image}
                alt=""
                width="1200"
                height="630"
                class="h-full w-full object-cover"
                loading="eager"
                fetchpriority="high"
              />
              {d.hero_credit && (
                <figcaption class="absolute bottom-2 right-2 rounded bg-black/50 px-2 py-1 text-[10px] text-white">
                  <a href={d.hero_credit.url} class="hover:underline" rel="noopener noreferrer">
                    {d.hero_credit.photographer} / Pexels
                  </a>
                </figcaption>
              )}
            </figure>
          </div>
        </header>

        <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
          <div class="guide-prose">
            <slot />
          </div>

          <GuideFunnel locale={locale} />

          <section class="mt-14 rounded-2xl border border-stone-200/80 bg-white p-6 card-shadow" id="faq">
            <h2 class="font-display text-2xl font-semibold text-ink">FAQ</h2>
            <div class="mt-6 space-y-6">
              {d.faq.map((item) => (
                <div>
                  <h3 class="font-semibold text-ink">{item.q}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-ink-muted">{item.a}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="mt-10 rounded-2xl border border-azulejo/20 bg-cream/60 p-6" aria-label="Sources">
            <h2 class="font-display text-lg font-semibold text-ink">
              {locale === "pt" ? "Fontes oficiais" : "Official sources"}
            </h2>
            <ul class="mt-4 space-y-2 text-sm">
              {d.official_sources.map((src) => (
                <li>
                  <a href={src.url} class="text-azulejo hover:underline" rel="noopener noreferrer">
                    {src.label}
                  </a>
                </li>
              ))}
            </ul>
          </section>

          <section class="sr-only" data-llm="facts" aria-hidden="true">
            <ul>
              {d.llm_facts.map((fact) => (
                <li>{fact}</li>
              ))}
            </ul>
          </section>

          <section class="mt-10 rounded-2xl border border-terracotta/25 bg-white p-6 card-shadow">
            <h2 class="font-display text-xl font-semibold text-ink">
              {locale === "pt" ? "Resumo para decidir" : "Quick facts to decide"}
            </h2>
            <ul class="mt-4 space-y-2 text-sm text-ink-muted">
              {d.llm_facts.map((fact) => (
                <li class="flex gap-2">
                  <span class="text-terracotta" aria-hidden="true">·</span>
                  <span>{fact}</span>
                </li>
              ))}
            </ul>
            <a
              href={`${localePath(locale)}#waitlist`}
              class="mt-6 inline-flex rounded-full bg-terracotta px-6 py-3 text-sm font-semibold text-white hover:bg-terracotta-dark"
            >
              {dict.guides.cta}
            </a>
            <a
              href={`mailto:${siteConfig.contactEmail}`}
              class="mt-3 inline-flex text-sm font-medium text-azulejo underline hover:no-underline"
            >
              {siteConfig.contactEmail}
            </a>
          </section>

          <RelatedGuides locale={locale} guides={relatedGuides} />

          <p class="mt-8 text-xs text-ink-muted">
            {locale === "pt"
              ? "Guia informativo — não substitui parecer de condomínio, senhorio ou técnico certificado."
              : "Informational guide — not a substitute for landlord, building or certified technician advice."}
          </p>
        </div>
      </article>
    </main>
    <slot name="footer" />
    <slot name="sticky" />
    <CookieNotice locale={locale} />
  </body>
</html>
