---
import { getGuides, guidePath, getGuideAlternate, getRelatedGuides } from "../../lib/guides";
import GuideLayout from "../../layouts/GuideLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { render } from "astro:content";

export async function getStaticPaths() {
  const guides = await getGuides("pt");
  return Promise.all(
    guides.map(async (entry) => {
      const alt = await getGuideAlternate(entry, "pt");
      return {
        params: { slug: entry.id },
        props: { entry, alternatePath: alt ? guidePath("en", alt.id) : undefined },
      };
    }),
  );
}

const { entry, alternatePath } = Astro.props;
const relatedGuides = await getRelatedGuides(entry, "pt");
const { Content } = await render(entry);
---

<GuideLayout locale="pt" entry={entry} slug={entry.id} alternatePath={alternatePath} relatedGuides={relatedGuides}>
  <Header slot="header" locale="pt" />
  <Content />
  <Footer slot="footer" locale="pt" />
</GuideLayout>
