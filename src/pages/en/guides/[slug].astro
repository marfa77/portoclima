---
import { getGuides, guidePath } from "../../../lib/guides";
import GuideLayout from "../../../layouts/GuideLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { render } from "astro:content";
import { getGuideAlternate } from "../../../lib/guides";

export async function getStaticPaths() {
  const guides = await getGuides("en");
  return Promise.all(
    guides.map(async (entry) => {
      const alt = await getGuideAlternate(entry, "en");
      return {
        params: { slug: entry.id },
        props: { entry, alternatePath: alt ? guidePath("pt", alt.id) : undefined },
      };
    }),
  );
}

const { entry, alternatePath } = Astro.props;
const { Content } = await render(entry);
---

<GuideLayout locale="en" entry={entry} slug={entry.id} alternatePath={alternatePath}>
  <Header slot="header" locale="en" />
  <Content />
  <Footer slot="footer" locale="en" />
</GuideLayout>
